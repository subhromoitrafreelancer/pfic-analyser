# EODHD API key — get from https://eodhd.com/cp/settings
EODHD_API_KEY=your_key_here

# SQLite file path
# Local dev: leave as default (creates pfic.db in project root)
# Railway: set to your persistent volume mount path, e.g. /data/pfic.db
DATABASE_PATH=./pfic.db

# EODHD response cache duration in hours (0 = disable cache)
CACHE_TTL_HOURS=24

# Max parallel EODHD requests
# Free/trial plan: 1-2  |  Paid plan: 10-20
MAX_CONCURRENT=5

# Sessions expire after this many days (shareable /results/:id URL)
SESSION_TTL_DAYS=7

PORT=3000
